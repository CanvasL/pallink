(common) {
	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy no-referrer-when-downgrade
	}
}

localhost, 127.0.0.1 {
	import common

	redir /docs /swagger/

	handle /docs/* {
		redir /swagger/ 308
	}

	redir /swagger /swagger/

	handle /swagger/* {
		reverse_proxy swagger-ui:8080
	}

	reverse_proxy gateway-api:8080
}

pghero.localhost {
	import common

	reverse_proxy pghero:8080
}

prometheus.localhost {
	import common

	reverse_proxy prometheus:9090
}

grafana.localhost {
	import common

	reverse_proxy grafana:3000
}
