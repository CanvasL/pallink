(common) {
	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy no-referrer-when-downgrade
	}
}

{$API_HOST} {
	import common

	redir /docs /swagger/

	handle /docs/* {
		redir /swagger/ 308
	}

	redir /swagger /swagger/

	handle /swagger/* {
		reverse_proxy swagger-ui:8080
	}

	reverse_proxy gateway-api:8080
}

{$GRAFANA_HOST} {
	import common

	reverse_proxy grafana:3000
}

{$PGHERO_HOST} {
	import common

	reverse_proxy pghero:8080
}
