# Aliyun ACR registry settings.
# Use the exact login server shown in the ACR console.
# Examples:
#   New personal edition: crpi-xxxx.cn-hangzhou.personal.cr.aliyuncs.com
#   Legacy personal edition: registry.cn-hangzhou.aliyuncs.com
#   Enterprise edition: <instance>-registry.cn-hangzhou.cr.aliyuncs.com
# The docker login domain and the push domain must be identical.

ALIYUN_REGISTRY=registry.cn-hangzhou.aliyuncs.com

# Application image namespace and tag.
# Expected repos:
#   gateway-api
#   user-rpc
#   activity-rpc
#   notification-rpc
#   im-rpc
#   audit-worker
ALIYUN_APP_NAMESPACE=pallink
APP_TAG=latest

# Third-party mirror namespace.
# Expected repos:
#   postgres
#   etcd
#   rabbitmq
#   redis
#   caddy
#   swagger-ui
#   pghero
#   prometheus
#   grafana
# The namespace must already exist in ACR.
# If automatic repository creation is disabled, create the repos above in advance.
ALIYUN_MIRROR_NAMESPACE=pallink-mirror
