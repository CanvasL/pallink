# Aliyun ACR registry settings.
# Use the exact login server shown in the ACR console.
# Examples:
#   New personal edition: crpi-xxxx.cn-hangzhou.personal.cr.aliyuncs.com
#   Legacy personal edition: registry.cn-hangzhou.aliyuncs.com
#   Enterprise edition: <instance>-registry.cn-hangzhou.cr.aliyuncs.com
# The docker login domain and the push domain must be identical.

ALIYUN_REGISTRY=registry.cn-hangzhou.aliyuncs.com

# Application image namespace and tag.
# Expected repos:
#   gateway-api
#   user-rpc
#   activity-rpc
#   notification-rpc
#   im-rpc
#   audit-worker
ALIYUN_APP_NAMESPACE=pallink
APP_TAG=latest

# Third-party mirror namespace.
# Expected repos:
#   postgres
#   etcd
#   rabbitmq
#   redis
#   caddy
#   swagger-ui
#   pghero
#   prometheus
#   grafana
# The namespace must already exist in ACR.
# If automatic repository creation is disabled, create the repos above in advance.
ALIYUN_MIRROR_NAMESPACE=pallink-mirror

# Public hostnames for the Aliyun deployment.
API_HOST=api.pallink.us.ci
PROMETHEUS_HOST=prometheus.pallink.us.ci
GRAFANA_HOST=grafana.pallink.us.ci
PGHERO_HOST=pghero.pallink.us.ci

# Use the Aliyun-specific Caddyfile and standard HTTP/HTTPS ports.
CADDYFILE_PATH=./deploy/caddy/Caddyfile.aliyun
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Swagger UI is served from https://$API_HOST/docs/
SWAGGER_UI_PERSIST_AUTHORIZATION=true

# Prometheus is served from https://$PROMETHEUS_HOST/
PROMETHEUS_EXTERNAL_URL=https://prometheus.pallink.us.ci/
