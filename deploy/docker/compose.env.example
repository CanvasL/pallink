# Public hostnames for a subdomain-based deployment.
API_HOST=api.example.com
PROMETHEUS_HOST=prometheus.example.com
GRAFANA_HOST=grafana.example.com
PGHERO_HOST=pghero.example.com

# Use the public Caddyfile and standard HTTP/HTTPS ports.
CADDYFILE_PATH=./deploy/docker/Caddyfile.prod
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Swagger UI is served from https://$API_HOST/docs/
SWAGGER_UI_PERSIST_AUTHORIZATION=true

# Prometheus is served from https://$PROMETHEUS_HOST/
PROMETHEUS_EXTERNAL_URL=https://prometheus.example.com/
